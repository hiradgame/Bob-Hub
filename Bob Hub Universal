local function addToggle(p, t, c)
	local b = Instance.new("TextButton", p); b.Size = UDim2.new(1, -10, 0, 65); b.BackgroundColor3 = Color3.fromRGB(25, 25, 25); b.Text = t .. ": OFF"; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 22; Instance.new("UICorner", b)
	local a = false; b.MouseButton1Click:Connect(function() a = not a; b.Text = t .. ": " .. (a and "ON" or "OFF"); b.BackgroundColor3 = a and Color3.fromRGB(85, 170, 255) or Color3.fromRGB(25, 25, 25); c(a) end)
end

