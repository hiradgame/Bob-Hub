--// MASTER ENGINE
RunService.RenderStepped:Connect(function()
	local char = player.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if hrp then
		if State.Fly then
			local m = Vector3.zero
			if keys.W then m += camera.CFrame.LookVector end if keys.S then m -= camera.CFrame.LookVector end
			if keys.A then m -= camera.CFrame.RightVector end if keys.D then m += camera.CFrame.RightVector end
			hrp.Velocity = m.Unit * State.FlySpeed
		elseif not State.Fly and hrp.Velocity.Magnitude > 0 and hrp.Velocity.Y == 0 then
			-- Reset velocity when fly is off to prevent sliding
		end
		if State.Noclip then for _, p in pairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
		if State.Spinbot then hrp.CFrame *= CFrame.Angles(0, math.rad(25), 0) end
	end
	if State.ESP then
		ESPFolder:ClearAllChildren()
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
				local h = Instance.new("Highlight", ESPFolder); h.Adornee = p.Character; h.FillColor = p.TeamColor.Color
				local b = Instance.new("BillboardGui", ESPFolder); b.Adornee = p.Character.Head; b.Size = UDim2.fromOffset(100,50); b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0,3,0)
				local l = Instance.new("TextLabel", b); l.Size = UDim2.fromScale(1,1); l.BackgroundTransparency = 1; l.Text = p.Name.."\nHP: "..math.floor(p.Character.Humanoid.Health); l.TextColor3 = Color3.new(1,1,1); l.Font = Enum.Font.GothamBold; l.TextSize = 14
			end
		end
	end
	if State.Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
		local c = nil; local d = 400
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
				local m = (camera.CFrame.Position - p.Character.Head.Position).Magnitude
				if m < d then d = m; c = p end
			end
		end
		if c then camera.CFrame = CFrame.new(camera.CFrame.Position, c.Character.Head.Position) end
	end
end)

--// INPUTS & DRAG
UIS.InputBegan:Connect(function(i, g) if not g then keys[i.KeyCode.Name] = true; if i.KeyCode == Enum.KeyCode.RightShift then main.Visible = not main.Visible end end end)
UIS.InputEnded:Connect(function(i) keys[i.KeyCode.Name] = false end)
UIS.JumpRequest:Connect(function() if State.InfiniteJump and player.Character then player.Character.Humanoid:ChangeState(3) end end)
mouse.Button1Down:Connect(function()
	if State.ClickTP and UIS:IsKeyDown(Enum.KeyCode.LeftControl) then player.Character.HumanoidRootPart.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0,3,0)) end
	if State.ClickDelete and UIS:IsKeyDown(Enum.KeyCode.LeftAlt) then if mouse.Target then mouse.Target:Destroy() end end
end)

local drag, res, start, pos, sSize
titleBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true; start = i.Position; pos = main.Position end end)
resizer.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then res = true; start = i.Position; sSize = main.Size end end)
UIS.InputChanged:Connect(function(i)
	if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = i.Position - start; main.Position = UDim2.new(pos.X.Scale, pos.X.Offset + delta.X, pos.Y.Scale, pos.Y.Offset + delta.Y)
	elseif res and i.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = i.Position - start; main.Size = UDim2.fromOffset(math.max(500, sSize.X.Offset + delta.X), math.max(200, sSize.Y.Offset + delta.Y))
	end
end)
UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false; res = false end end)
